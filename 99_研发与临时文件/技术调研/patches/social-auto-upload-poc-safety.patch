index 0000000..7387f43
--- /dev/null
+++ b/tests/test_douyin_uploader.py
@@ -0,0 +1,214 @@
+import asyncio
+import unittest
+
+import uploader.douyin_uploader.main as douyin_main
+
+
+class RecordingButton:
+    def __init__(self):
+        self.clicks = 0
+
+    @property
+    def first(self):
+        return self
+
+    async def count(self):
+        return 1
+
+    async def click(self, **kwargs):
+        self.clicks += 1
+
+    async def is_visible(self):
+        return True
+
+
+class SubmitPage:
+    def __init__(self, wait_results):
+        self.button = RecordingButton()
+        self.wait_results = list(wait_results)
+        self.wait_calls = []
+        self.screenshot_calls = 0
+
+    def get_by_role(self, role, name, exact=False):
+        return self.button
+
+    async def wait_for_url(self, pattern, timeout):
+        self.wait_calls.append((pattern, timeout))
+        result = self.wait_results.pop(0)
+        if isinstance(result, Exception):
+            raise result
+
+    async def screenshot(self, **kwargs):
+        self.screenshot_calls += 1
+
+
+class RecordingLocator:
+    def __init__(self):
+        self.filled = []
+        self.wait_calls = []
+        self.clicks = 0
+        self.hidden_waits = []
+
+    @property
+    def first(self):
+        return self
+
+    async def fill(self, value):
+        self.filled.append(value)
+
+    async def click(self):
+        self.clicks += 1
+
+    async def count(self):
+        return 1
+
+    async def is_visible(self):
+        return True
+
+    async def wait_for(self, **kwargs):
+        if kwargs.get("state") == "hidden":
+            self.hidden_waits.append(kwargs)
+        else:
+            self.wait_calls.append(kwargs)
+
+
+class RecordingKeyboard:
+    def __init__(self):
+        self.actions = []
+
+    async def press(self, key):
+        self.actions.append(("press", key))
+
+    async def type(self, value):
+        self.actions.append(("type", value))
+
+
+class ContentPage:
+    def __init__(self):
+        self.title_input = RecordingLocator()
+        self.description_editor = RecordingLocator()
+        self.keyboard = RecordingKeyboard()
+
+    def locator(self, selector):
+        if selector.startswith('input[placeholder'):
+            return self.title_input
+        return self.description_editor
+
+
+class SmsPage:
+    def __init__(self):
+        self.sms_input = RecordingLocator()
+        self.get_code_button = RecordingButton()
+
+    def locator(self, selector):
+        return self.sms_input
+
+    def get_by_text(self, text, exact=False):
+        return self.get_code_button
+
+
+class DouyinUploaderSafetyTests(unittest.TestCase):
+    def test_headed_sms_verification_waits_for_browser_without_reading_code(self):
+        page = SmsPage()
+        uploader = type("Uploader", (), {"headless": False})()
+
+        result = asyncio.run(
+            douyin_main.DouYinVideo._handle_sms_challenge_after_submit(
+                uploader,
+                page,
+            )
+        )
+
+        self.assertTrue(result)
+        self.assertEqual(page.get_code_button.clicks, 1)
+        self.assertEqual(
+            page.sms_input.hidden_waits,
+            [{"state": "hidden", "timeout": 120000}],
+        )
+
+    def test_description_is_written_before_tags(self):
+        page = ContentPage()
+
+        asyncio.run(
+            douyin_main.DouYinBaseUploader.fill_title_and_description(
+                object(),
+                page,
+                "测试标题",
+                "正文内容",
+                ["话题1", "话题2"],
+            )
+        )
+
+        self.assertEqual(page.title_input.filled, ["测试标题"])
+        self.assertEqual(
+            page.keyboard.actions,
+            [
+                ("press", "Control+KeyA"),
+                ("press", "Delete"),
+                ("type", "正文内容"),
+                ("type", " #话题1"),
+                ("press", "Space"),
+                ("type", " #话题2"),
+                ("press", "Space"),
