.DS_Store
**/.DS_Store
**/__pycache__/
*.py[cod]
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.mobileprovision
.local-git-backups/

# Git tracks the reproducible workflow, not heavy delivery binaries.
**/*.mp4
**/*.mov
**/*.mkv
**/*.pptx
**/*.wav
**/*.mp3
**/*.m4a

# Deterministic local intermediates and contact sheets are regenerated by the SOP.
.work/
**/05_后期制作/**/work/

# Legacy local media mounts stay outside the repository.
/本地历史媒体_不进Git/

# Local third-party publishing repositories are research checkouts, not vendored code.
/99_研发归档/技术调研/research/douyin-account-publishing/

# Provider response metadata can contain signed URLs, request headers, or access identifiers.
**/*.source.json
**/*.job.json
**/*response-meta*.json
